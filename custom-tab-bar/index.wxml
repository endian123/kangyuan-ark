<view class="tab-bar safe-area-inset-bottom">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    data-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <view class="icon">
      <view wx:if="{{index === 0}}" class="icon-service"></view>
      <view wx:if="{{index === 1}}" class="icon-mine"></view>
    </view>
    <text class="text">{{item.text}}</text>
  </view>
</view>
