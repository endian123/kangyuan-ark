.service-page {
  padding-bottom: 160rpx;
}

/* Banner */
.banner {
  height: 280rpx;
  margin: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.banner-item {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  text-align: center;
}

.banner-item.bg1 {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
}

.banner-item.bg2 {
  background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
}

.banner-item.bg3 {
  background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%);
}

.banner-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.banner-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* Tab */
.tab-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx;
  margin-top: 0;
}

.tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 16rpx 0;
  border-radius: 44rpx;
  transition: all 0.2s;
}

.tab.active {
  background: var(--primary);
  color: #fff;
  font-weight: 500;
}

/* Order */
.order-list {
  margin-top: 8rpx;
}

.order-card {
  margin-bottom: 24rpx;
}

.order-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.order-id {
  font-size: 26rpx;
  color: var(--text-light);
}

.patient-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.patient-row .name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text);
  margin-right: 16rpx;
}

.patient-row .phone {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex: 1;
}

.patient-row .price {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
}

.info-label {
  width: 140rpx;
  font-size: 26rpx;
  color: var(--text-light);
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.action-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

/* 按钮样式修复 */
.btn-sm {
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  padding: 0 20rpx;
  border-radius: 30rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-plain.btn-sm {
  background: #fff;
  border: 2rpx solid #e5e5e5;
  color: var(--text);
}

.btn-ghost.btn-sm {
  background: var(--primary-light);
  color: var(--primary);
  border: none;
}

.btn-primary.btn-sm {
  background: var(--primary);
  color: #fff;
  border: none;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
  color: var(--text-light);
  font-size: 28rpx;
}

/* Modal */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 2000;
}

.modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 620rpx;
  background: #fff;
  border-radius: 32rpx;
  z-index: 2001;
  overflow: hidden;
}

.modal-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  padding: 36rpx 0 20rpx;
}

.modal-body {
  padding: 0 40rpx 36rpx;
}

.target-hospital {
  text-align: center;
  font-size: 30rpx;
  color: var(--text);
  font-weight: 500;
  margin-bottom: 16rpx;
}

.tip {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  text-align: center;
}

.modal-msg {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
}

.modal-msg.success {
  background: #d1fae5;
  color: var(--primary);
}

.modal-foot {
  display: flex;
  align-items: center;
  padding: 0 40rpx 40rpx;
  gap: 24rpx;
}

.modal-foot .btn-plain,
.modal-foot .btn-primary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
}

.modal-foot .btn-primary.disabled {
  opacity: 0.7;
}

/* 短信弹窗 */
.sms-modal {
  width: 680rpx;
}

.sms-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 28rpx;
}

.sms-label {
  color: var(--text-light);
}

.sms-templates {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sms-template {
  padding: 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  cursor: pointer;
}

.sms-template.active {
  border-color: var(--primary);
  background: var(--primary-light);
}

.tpl-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 8rpx;
}

.tpl-content {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}