.fillorder-page {
  padding-bottom: 160rpx;
}

.section-title {
  margin-bottom: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  border-bottom: 2rpx solid var(--border);
  padding: 16rpx 0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item.column {
  flex-direction: column;
  align-items: flex-start;
}

.form-item.column .label {
  margin-bottom: 12rpx;
}

.form-item .label {
  width: 180rpx;
  font-size: 28rpx;
  color: var(--text);
}

.form-item .label.required::after {
  content: '*';
  color: var(--danger);
  margin-left: 6rpx;
}

.form-item .input,
.form-item .picker {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.form-item .picker {
  color: var(--text-secondary);
}

.textarea {
  width: 100%;
  height: 160rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  padding: 16rpx;
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

.upload-box {
  width: 240rpx;
  height: 240rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-box image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: var(--text-light);
  font-size: 24rpx;
}

.upload-placeholder .plus {
  font-size: 56rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.sign-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  overflow: hidden;
}

.sign-canvas {
  width: 100%;
  height: 100%;
}

.sign-tips {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #cccccc;
  font-size: 28rpx;
  pointer-events: none;
}

.sign-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
}

.sign-actions .btn-plain,
.sign-actions .btn-ghost {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}

.sign-preview {
  margin-top: 24rpx;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
}

.sign-preview image {
  width: 100%;
  height: 160rpx;
}

.submit-wrap {
  margin: 32rpx 24rpx 40rpx;
}

.submit-wrap .btn-primary.disabled {
  opacity: 0.7;
}
