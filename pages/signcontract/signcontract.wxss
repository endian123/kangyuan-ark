.signcontract-page {
  padding-bottom: 160rpx;
}

.contract-content {
  max-height: 600rpx;
  overflow-y: auto;
}

.contract-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 24rpx;
}

.contract-body {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.paragraph {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 20rpx;
}

.sign-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  overflow: hidden;
}

.sign-canvas {
  width: 100%;
  height: 100%;
}

.sign-tips {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #cccccc;
  font-size: 28rpx;
  pointer-events: none;
}

.sign-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
}

.sign-actions .btn-plain,
.sign-actions .btn-ghost {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
}

.sign-preview {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
}

.sign-preview image {
  width: 100%;
  height: 160rpx;
}

.submit-wrap {
  margin: 32rpx 24rpx 40rpx;
}

.submit-wrap .btn-primary.disabled {
  opacity: 0.7;
}
