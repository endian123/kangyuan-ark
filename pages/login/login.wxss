.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #d1fae5 0%, #f5f7fa 60%, #fff 100%);
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
}

/* Logo区域 */
.logo-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 160rpx;
}

.logo-wrap {
  position: relative;
  margin-bottom: 32rpx;
}

.logo-icon {
  width: 180rpx;
  height: 180rpx;
  background: var(--primary);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 24rpx 64rpx rgba(16,185,129,0.3);
  position: relative;
}

.logo-heart {
  font-size: 80rpx;
  color: #fff;
}

.logo-pulse {
  position: absolute;
  inset: -16rpx;
  border: 4rpx solid var(--primary);
  border-radius: 56rpx;
  opacity: 0.3;
  animation: pulse 2s ease-out infinite;
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.1); opacity: 0.1; }
  100% { transform: scale(1); opacity: 0.3; }
}

.brand-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
}

.brand-slogan {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 授权按钮 */
.auth-section {
  padding-bottom: 120rpx;
}

.btn-wechat {
  width: 100%;
  height: 96rpx;
  background: var(--primary);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(16,185,129,0.2);
}

.btn-wechat::after {
  border: none;
}

.wechat-icon {
  width: 40rpx;
  height: 40rpx;
  background: #fff;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.icon-wechat {
  font-size: 20rpx;
  color: var(--primary);
  font-weight: 600;
}

.btn-manual {
  width: 100%;
  height: 96rpx;
  background: #fff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text);
  font-size: 32rpx;
  border: 2rpx solid var(--border);
}

/* 协议 */
.agree-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 48rpx;
  font-size: 24rpx;
}

.agree-section checkbox {
  margin-right: 8rpx;
}

.agree-text {
  color: var(--text-light);
}

.agree-link {
  color: var(--primary);
}

/* 手机号登录弹窗 */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 2000;
}

.phone-modal {
  position: fixed;
  left: 48rpx;
  right: 48rpx;
  bottom: 50%;
  transform: translateY(50%);
  background: #fff;
  border-radius: 32rpx;
  z-index: 2001;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--border);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text);
}

.modal-close {
  font-size: 48rpx;
  color: var(--text-light);
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.phone-input-wrap {
  margin-bottom: 24rpx;
}

.phone-input {
  width: 100%;
  height: 96rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
}

.code-row {
  display: flex;
  gap: 16rpx;
}

.code-input {
  flex: 1;
  height: 96rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
}

.btn-get-code {
  width: 200rpx;
  height: 96rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.btn-get-code.disabled {
  background: #ccc;
}

.modal-footer {
  padding: 16rpx 32rpx 32rpx;
}

.btn-confirm {
  width: 100%;
  height: 96rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-confirm.disabled {
  background: #ccc;
}