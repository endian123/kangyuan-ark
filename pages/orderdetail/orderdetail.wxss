.orderdetail-page {
  padding-bottom: 160rpx;
}

.status-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.order-id {
  font-size: 26rpx;
  color: var(--text-light);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-light);
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.info-value.price {
  color: var(--primary);
  font-weight: 600;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  border-top: 2rpx solid var(--border);
  display: flex;
  gap: 16rpx;
  z-index: 100;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.action-bar .btn-plain,
.action-bar .btn-ghost,
.action-bar .btn-primary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}
