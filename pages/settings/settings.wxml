        <text class="label">隐私协议</text>
        <text class="desc">了解个人信息保护说明</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="menu-item" bindtap="signContract">
      <view class="menu-icon orange">签署</view>
      <view class="menu-text">
        <text class="label">签署电子合同</text>
        <text class="desc">审核通过后在线签署入驻协议</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="menu-item" bindtap="contactService">
      <view class="menu-icon purple">客服</view>
      <view class="menu-text">
        <text class="label">联系客服</text>
        <text class="desc">400-123-4567</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
