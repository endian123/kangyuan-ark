<view class="page servicetime-page">
  <view class="page-header">
    <text class="back-btn" bindtap="goBack">‹</text>
    <text class="page-title">服务时间设置</text>
  </view>

  <view class="section-title">可服务时间段</view>
  <view class="card time-card">
    <view class="time-item" wx:for="{{timeSlots}}" wx:key="id">
      <view class="time-label">{{item.label}}</view>
      <view class="time-switch {{item.enabled ? 'active' : ''}}" data-id="{{item.id}}" bindtap="toggleTime">
        <view class="switch-dot"></view>
      </view>
    </view>
  </view>

  <view class="section-title">服务日期</view>
  <view class="card date-card">
    <view class="date-item" wx:for="{{weekdays}}" wx:key="id">
      <view class="date-label">{{item.label}}</view>
      <view class="date-btn {{item.selected ? 'active' : ''}}" data-id="{{item.id}}" bindtap="toggleDay">{{item.label}}</view>
    </view>
  </view>

  <view class="section-title">备注说明</view>
  <view class="card">
    <textarea class="remark-input" placeholder="请输入备注说明，如：法定节假日休息" value="{{remark}}" bindinput="onRemarkInput"></textarea>
  </view>

  <view class="submit-wrap">
    <view class="btn-primary" bindtap="saveSetting">保存设置</view>
  </view>
</view>