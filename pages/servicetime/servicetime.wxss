.servicetime-page {
  padding-bottom: 120rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin: 32rpx 24rpx 16rpx;
}

.time-card {
  padding: 8rpx 24rpx;
}

.time-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.time-item:last-child {
  border-bottom: none;
}

.time-label {
  font-size: 28rpx;
  color: var(--text);
}

.time-switch {
  width: 80rpx;
  height: 48rpx;
  background: #e5e5e5;
  border-radius: 24rpx;
  position: relative;
  transition: background 0.3s;
}

.time-switch.active {
  background: var(--primary);
}

.switch-dot {
  width: 40rpx;
  height: 40rpx;
  background: #fff;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: left 0.3s;
}

.time-switch.active .switch-dot {
  left: 36rpx;
}

.date-card {
  padding: 16rpx;
}

.date-item {
  display: inline-block;
  width: 14.28%;
  text-align: center;
  margin-bottom: 16rpx;
}

.date-label {
  display: none;
}

.date-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f5f5f5;
  color: var(--text);
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.date-btn.active {
  background: var(--primary);
  color: #fff;
}

.remark-input {
  width: 100%;
  height: 160rpx;
  border: none;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
}

.submit-wrap {
  margin: 32rpx 24rpx;
}