.mine-page {
  position: relative;
  padding-bottom: 160rpx;
}

.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(180deg, #10B981 0%, #059669 100%);
  border-radius: 0 0 40rpx 40rpx;
  z-index: 0;
}

.user-card {
  position: relative;
  z-index: 1;
  margin-top: 120rpx;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  margin-right: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--primary-light);
}

.avatar.default {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--primary);
  font-weight: 600;
}

.user-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.name {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text);
  margin-right: 16rpx;
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.status-badge.unsettled { background: #f5f5f5; color: #999; }
.status-badge.auditing { background: #fff7e6; color: #fa8c16; }
.status-badge.settled { background: #d1fae5; color: var(--primary); }
.status-badge.rejected { background: #fff1f0; color: #ff4d4f; }

.phone {
  font-size: 26rpx;
  color: var(--text-light);
}

.user-card .arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* 服务单量 */
.volume-card {
  margin-top: 24rpx;
}

.volume-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.volume-head .section-title {
  margin-bottom: 0;
}

.volume-more {
  font-size: 24rpx;
  color: var(--primary);
}

.volume-body {
  display: flex;
  justify-content: space-around;
}

.volume-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.volume-item .num {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
}

.volume-item .label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

/* 入驻流程 */
.flow-card {
  margin-top: 24rpx;
}

.flow-steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 20rpx;
  color: var(--text-light);
}

.step .dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #e5e5e5;
  margin-bottom: 10rpx;
}

.step .dot.active {
  background: var(--primary);
}

.step .line {
  flex: 1;
  height: 2rpx;
  background: #e5e5e5;
  margin: 0 6rpx;
  margin-bottom: 30rpx;
}

/* 我的工具 */
.tools-card {
  margin-top: 24rpx;
}

.tools-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 20rpx;
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
}

.tool-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

/* 线性图标 - 纯CSS实现 */
.icon-cert {
  width: 44rpx;
  height: 52rpx;
  border: 4rpx solid var(--text);
  border-radius: 6rpx;
  position: relative;
}
.icon-cert::before {
  content: '';
  position: absolute;
  top: 12rpx;
  left: 8rpx;
  right: 8rpx;
  height: 4rpx;
  background: var(--text);
}
.icon-cert::after {
  content: '';
  position: absolute;
  top: 22rpx;
  left: 8rpx;
  width: 16rpx;
  height: 4rpx;
  background: var(--text);
}

.icon-time {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--text);
  border-radius: 50%;
  position: relative;
}
.icon-time::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 14rpx;
  background: var(--text);
}
.icon-time::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 6rpx;
  width: 12rpx;
  height: 4rpx;
  background: var(--text);
}

.icon-sms {
  width: 48rpx;
  height: 40rpx;
  border: 4rpx solid var(--text);
  border-radius: 12rpx;
  position: relative;
}
.icon-sms::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8rpx;
  height: 8rpx;
  background: var(--text);
  border-radius: 50%;
  box-shadow: 14rpx 0 0 var(--text), -14rpx 0 0 var(--text);
}

.icon-setting {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--text);
  border-radius: 50%;
  position: relative;
}
.icon-setting::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  border: 4rpx solid var(--text);
  border-radius: 50%;
  background: #fff;
}

.tool-label {
  font-size: 24rpx;
  color: var(--text);
  text-align: center;
}

.version {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 48rpx;
}