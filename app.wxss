/* 全局样式 - 康元方舟陪同端 */
page {
  --primary: #10B981;
  --primary-light: #d1fae5;
  --primary-dark: #059669;
  --text: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --bg: #f5f7fa;
  --card: #ffffff;
  --border: #eeeeee;
  --danger: #ff4d4f;
  --warning: #faad14;
  --radius: 24rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.5;
}

.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.card {
  background: var(--card);
  border-radius: var(--radius);
  margin: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.btn-primary:active {
  background: var(--primary-dark);
}

.btn-ghost {
  background: var(--primary-light);
  color: var(--primary);
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.btn-ghost:active {
  background: #a7f3d0;
}

.btn-plain {
  background: #fff;
  color: var(--text-secondary);
  border: 2rpx solid var(--border);
  border-radius: 44rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  text-align: center;
  padding: 0 24rpx;
}

.btn-plain:active {
  background: #f9fafb;
}

.btn-small {
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  padding: 0 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 20rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-wait { background: #fff7e6; color: #fa8c16; }
.tag-running { background: #e6f7ff; color: #1890ff; }
.tag-done { background: #d1fae5; color: var(--primary); }

.divider {
  height: 2rpx;
  background: var(--border);
  margin: 24rpx 0;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}